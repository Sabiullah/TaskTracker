# TaskTracker — host nginx reverse proxy.
#
# Template — provision.yml substitutes the following placeholders before
# enabling the site:
#   {{LISTEN_HTTP}}   — 80  (domain mode) or 8000 (ip mode)
#   {{SERVER_NAME}}   — the actual domain, or "_" in ip mode
#   /srv/tasktracker  — replaced with your APP_DIR
#
# Assumes:
#   - docker compose is running the app on 127.0.0.1:8001
#   - $APP_DIR is the repo checkout on the host
#   - $APP_DIR/staticfiles, $APP_DIR/uploads, $APP_DIR/frontend/task-tracker/dist
#     are bind-mounted from the app container and readable by nginx
#   - TLS (domain mode only) is added by certbot after provisioning
#
# File serving: uploads are NOT served by nginx. Django's per-resource
# download actions (``/api/invoice_entries/<uid>/download/``,
# ``/api/employees/<uid>/address_proof/``,
# ``/api/chat_messages/<uid>/download/``) stream the file directly after
# an auth + org-visibility check. Nginx just forwards the request.

upstream tasktracker_app {
    server 127.0.0.1:8001;
    keepalive 32;
}

server {
    listen {{LISTEN_HTTP}};
    server_name {{SERVER_NAME}};

    # Uncomment after certbot runs (domain mode only):
    # listen 443 ssl http2;
    # ssl_certificate     /etc/letsencrypt/live/{{SERVER_NAME}}/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/{{SERVER_NAME}}/privkey.pem;

    client_max_body_size 25m;         # matches FILE_UPLOAD_MAX_MEMORY_SIZE in settings.py

    # Serve every text response with an explicit UTF-8 charset so browsers
    # never guess the encoding (multi-byte names/emoji in the JS bundle and
    # API payloads depend on it).
    charset utf-8;
    charset_types text/css application/javascript application/json image/svg+xml;

    # Hardening
    add_header X-Frame-Options        "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff"    always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # Gzip (brotli if mod_brotli is installed)
    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;

    root  /srv/tasktracker/frontend/task-tracker/dist;
    index index.html;

    # ── Django static files (admin, DRF) ────────────────────────────────
    location /static/ {
        alias /srv/tasktracker/staticfiles/;
        access_log off;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # ── Built React frontend (assets hashed, long cache) ────────────────
    location /assets/ {
        alias /srv/tasktracker/frontend/task-tracker/dist/assets/;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ── WebSockets (Channels) ───────────────────────────────────────────
    location /ws/ {
        proxy_pass http://tasktracker_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_set_header Host              $host:$server_port;
        proxy_set_header X-Forwarded-Host  $host:$server_port;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # ── API + admin ─────────────────────────────────────────────────────
    # CRITICAL: forward Host WITH port so Django's build_absolute_uri
    # emits full external URLs. Without ``:$server_port`` the file-
    # download links Django serialises for ``file_url`` come back
    # missing the port and the browser hits the wrong origin.
    location ~ ^/(api|admin)/ {
        proxy_pass http://tasktracker_app;
        proxy_http_version 1.1;
        proxy_set_header Host              $host:$server_port;
        proxy_set_header X-Forwarded-Host  $host:$server_port;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";
        # Streaming downloads (invoice / address-proof / chat) can be
        # large; default 60s proxy_read_timeout trips on slow clients.
        proxy_read_timeout 300s;
    }

    # ── SPA fallback — every non-API path must serve index.html ────────
    # Without this, direct navigation to e.g. /users returns 404 because
    # no ``/users`` file exists in the dist build — React Router does
    # the routing client-side after index.html loads.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
