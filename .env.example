# Copy to .env and fill in values for local dev.
# Production: set these as real environment variables on the server — never
# commit real secrets. Rotating SECRET_KEY invalidates every outstanding
# auth JWT (users will need to log in again).

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev). In production (docker-compose) this is overridden in the
# compose file to postgres://…@postgres:5432/…
DATABASE_URL=sqlite:///db.sqlite3

# Postgres service (docker-compose.yml reads these directly, and the app's
# DATABASE_URL is built from them in compose).
POSTGRES_DB=tasktracker
POSTGRES_USER=tasktracker
POSTGRES_PASSWORD=change-me

# Container image tag the VPS should run. Set to a specific SHA to pin
# (e.g. `ghcr.io/owner/repo:sha-abc123`). Defaults to :latest if unset —
# useful for local bootstrapping, but in prod deploy.yml rewrites this to
# a SHA tag on every deploy so rollbacks are precise.
APP_IMAGE=ghcr.io/OWNER/REPO:latest

# ── CORS / frontend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── CSRF ──────────────────────────────────────────────────────────────────────
# Origins trusted for state-changing requests (admin login, form POSTs).
# MUST include scheme + host (+ port if non-standard). Comma-separated.
# Examples:
#   http://49.12.190.43:8000           (IP mode, HTTP)
#   https://app.example.com            (domain mode, HTTPS)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# ── Redis / Channels ──────────────────────────────────────────────────────────
# Required for the WebSocket realtime layer (Channels). Optional if the app
# is run WSGI-only with no `/ws/` usage.
REDIS_URL=redis://localhost:6379

# ── File storage ──────────────────────────────────────────────────────────────
# Uploads are stored on disk under UPLOAD_DIR (relative to project root)
# and served by auth-gated viewset actions — no signed URLs, no tokens:
#   /api/invoice_entries/<uid>/download/
#   /api/employees/<uid>/address_proof/
#   /api/chat_messages/<uid>/download/
# Each endpoint requires ``IsAuthenticated`` and is scoped by the
# viewset's org-visible queryset. Append ``?download=1`` to force a
# save-as instead of inline browser rendering.
UPLOAD_DIR=uploads

# ── Seed script credentials ───────────────────────────────────────────────────
# Used only by `uv run python manage.py seed_initial_data` when creating the
# initial admin + team members on a fresh database. If unset, the script
# generates a random password and prints it once to stdout.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
SEED_EMPLOYEE_PASSWORD=change-me
# Which Org the seeded users + data belong to. If unset, the script uses
# the first existing Org or creates one called "Default".
SEED_ORG=Default
