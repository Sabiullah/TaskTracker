{
  "_instructions": [
    "Copy this file to mapping.json and fill it in.",
    "Give supabase_schema.json + local_schema.json to AI and ask it to create the mapping.",
    "Tables are imported in order: lowest 'order' first (handle dependencies: orgs→users→employees).",
    "'skip': true skips a table entirely.",
    "'fields': direct column-to-column copy. 'value_map' optionally remaps enum values.",
    "'lookups': FK fields — give the Supabase column and where to find the local integer PK.",
    "'static': hardcoded values to set on every row (e.g. org_id if you have one org)."
  ],
  "tables": [
    {
      "order": 1,
      "supabase_table": "orgs",
      "local_table": "users_org",
      "note": "Top-level tenant",
      "skip": false,
      "fields": {
        "name": {"to": "name"}
      },
      "lookups": {},
      "static": {}
    },
    {
      "order": 2,
      "supabase_table": "profiles",
      "local_table": "users_user",
      "note": "User accounts — map Supabase profile to Django User",
      "skip": false,
      "fields": {
        "email":        {"to": "email"},
        "full_name":    {"to": "full_name"},
        "role":         {
          "to": "role",
          "value_map": {
            "admin":    "admin",
            "manager":  "manager",
            "employee": "employee"
          }
        },
        "avatar_color": {"to": "avatar_color"}
      },
      "lookups": {
        "org_id": {"to": "org_id", "local_table": "users_org", "match_field": "uid"}
      },
      "static": {
        "is_active":          true,
        "is_staff":           false,
        "invoice_access":     false,
        "notice_access":      false,
        "masters_access":     false,
        "attendance_access":  false,
        "employee_access":    false
      }
    },
    {
      "order": 3,
      "supabase_table": "masters",
      "local_table": "masters_master",
      "note": "Clients, categories, teams",
      "skip": false,
      "fields": {
        "name":       {"to": "name"},
        "type":       {
          "to": "type",
          "value_map": {
            "client":   "client",
            "category": "category",
            "team":     "team"
          }
        },
        "color":      {"to": "color"},
        "is_active":  {"to": "is_active"},
        "sort_order": {"to": "sort_order"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",  "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user", "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 4,
      "supabase_table": "employees",
      "local_table": "employees_employee",
      "note": "Employee profiles",
      "skip": false,
      "fields": {
        "employee_name":              {"to": "employee_name"},
        "date_of_joining":            {"to": "date_of_joining"},
        "date_of_birth":              {"to": "date_of_birth"},
        "gender":                     {"to": "gender"},
        "blood_group":                {"to": "blood_group"},
        "marital_status":             {"to": "marital_status"},
        "father_name":                {"to": "father_name"},
        "phone":                      {"to": "phone"},
        "alt_phone":                  {"to": "alt_phone"},
        "email":                      {"to": "email"},
        "permanent_address":          {"to": "permanent_address"},
        "current_address":            {"to": "current_address"},
        "aadhar_number":              {"to": "aadhar_number"},
        "pan_number":                 {"to": "pan_number"},
        "bank_name":                  {"to": "bank_name"},
        "bank_account":               {"to": "bank_account"},
        "ifsc_code":                  {"to": "ifsc_code"},
        "emergency_contact_name":     {"to": "emergency_contact_name"},
        "emergency_contact_phone":    {"to": "emergency_contact_phone"},
        "emergency_contact_relation": {"to": "emergency_contact_relation"},
        "reference_name":             {"to": "reference_name"},
        "reference_contact":          {"to": "reference_contact"},
        "reference_relation":         {"to": "reference_relation"},
        "status":                     {"to": "status"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",  "match_field": "uid"},
        "user_id":       {"to": "user_id",       "local_table": "users_user", "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user", "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 5,
      "supabase_table": "tasks",
      "local_table": "tasks_task",
      "note": "Tasks",
      "skip": false,
      "fields": {
        "title":          {"to": "title"},
        "description":    {"to": "description"},
        "status":         {"to": "status"},
        "target_date":    {"to": "target_date"},
        "expected_date":  {"to": "expected_date"},
        "completed_date": {"to": "completed_date"},
        "remarks":        {"to": "remarks"},
        "recurrence":     {"to": "recurrence"}
      },
      "lookups": {
        "org_id":          {"to": "org_id",          "local_table": "users_org",    "match_field": "uid"},
        "responsible_id":  {"to": "responsible_id",  "local_table": "users_user",   "match_field": "uid"},
        "created_by_id":   {"to": "created_by_id",   "local_table": "users_user",   "match_field": "uid"},
        "client_id":       {"to": "client_id",       "local_table": "masters_master","match_field": "uid"},
        "category_id":     {"to": "category_id",     "local_table": "masters_master","match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 6,
      "supabase_table": "attendance",
      "local_table": "attendance_attendance",
      "note": "Attendance records",
      "skip": false,
      "fields": {
        "date":          {"to": "date"},
        "login_time":    {"to": "login_time"},
        "logout_time":   {"to": "logout_time"},
        "work_location": {"to": "work_location"},
        "status":        {"to": "status"},
        "remarks":       {"to": "remarks"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",  "match_field": "uid"},
        "user_id":       {"to": "user_id",       "local_table": "users_user", "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user", "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 7,
      "supabase_table": "work_logs",
      "local_table": "worklog_worklog",
      "note": "Daily work logs",
      "skip": false,
      "fields": {
        "date":             {"to": "date"},
        "task_description": {"to": "task_description"},
        "hours_worked":     {"to": "hours_worked"},
        "priority":         {"to": "priority"},
        "sort_order":       {"to": "sort_order"}
      },
      "lookups": {
        "org_id":    {"to": "org_id",    "local_table": "users_org",    "match_field": "uid"},
        "user_id":   {"to": "user_id",   "local_table": "users_user",   "match_field": "uid"},
        "client_id": {"to": "client_id", "local_table": "masters_master","match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 8,
      "supabase_table": "leads",
      "local_table": "leads_lead",
      "note": "Sales leads",
      "skip": false,
      "fields": {
        "contact_person":  {"to": "contact_person"},
        "contact_email":   {"to": "contact_email"},
        "contact_phone":   {"to": "contact_phone"},
        "lead_source":     {"to": "lead_source"},
        "reference_from":  {"to": "reference_from"},
        "priority":        {"to": "priority"},
        "estimated_value": {"to": "estimated_value"},
        "action_taken":    {"to": "action_taken"},
        "next_step":       {"to": "next_step"},
        "next_step_date":  {"to": "next_step_date"},
        "remarks":         {"to": "remarks"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",    "match_field": "uid"},
        "client_id":     {"to": "client_id",     "local_table": "masters_master","match_field": "uid"},
        "assigned_to_id":{"to": "assigned_to_id","local_table": "users_user",   "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user",   "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 9,
      "supabase_table": "holidays",
      "local_table": "holidays_holiday",
      "skip": false,
      "fields": {
        "name": {"to": "name"},
        "date": {"to": "date"},
        "type": {"to": "type"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",  "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user", "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 10,
      "supabase_table": "notices",
      "local_table": "notices_notice",
      "skip": false,
      "fields": {
        "dispute_nature":  {"to": "dispute_nature"},
        "fy":              {"to": "fy"},
        "received_date":   {"to": "received_date"},
        "replied_date":    {"to": "replied_date"},
        "next_target_date":{"to": "next_target_date"},
        "remarks":         {"to": "remarks"},
        "status":          {"to": "status"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",    "match_field": "uid"},
        "client_id":     {"to": "client_id",     "local_table": "masters_master","match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user",   "match_field": "uid"}
      },
      "static": {}
    },
    {
      "order": 11,
      "supabase_table": "growth_plans",
      "local_table": "growth_growthplan",
      "skip": false,
      "fields": {
        "activity":      {"to": "activity"},
        "target_month":  {"to": "target_month"},
        "steps_taken":   {"to": "steps_taken"},
        "steps_to_take": {"to": "steps_to_take"},
        "status":        {"to": "status"},
        "priority":      {"to": "priority"},
        "remarks":       {"to": "remarks"}
      },
      "lookups": {
        "org_id":        {"to": "org_id",        "local_table": "users_org",  "match_field": "uid"},
        "assigned_to_id":{"to": "assigned_to_id","local_table": "users_user", "match_field": "uid"},
        "created_by_id": {"to": "created_by_id", "local_table": "users_user", "match_field": "uid"}
      },
      "static": {}
    }
  ]
}
